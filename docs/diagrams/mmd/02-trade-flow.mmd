flowchart TB
  subgraph ORDER_STAGE["下单阶段"]
    direction LR
    SELECT["浏览商品与购物车<br/>选择 SKU / 数量"]:::user --> CREATE["mall-order<br/>创建订单"]:::service
    CREATE --> VERIFY["mall-product 校验价格<br/>mall-inventory 锁定库存"]:::service
    VERIFY --> ORDER_OK["返回 orderNo<br/>订单待支付"]:::success
  end

  subgraph PAY_STAGE["支付消息阶段"]
    direction LR
    PAY["mall-pay<br/>模拟支付成功"]:::service --> MQ["RocketMQ<br/>PAY_RESULT"]:::message
    MQ --> UPDATE["mall-order 标记已支付<br/>mall-inventory 确认扣减"]:::service
    UPDATE --> QUERY["查询订单<br/>展示最新状态"]:::success
  end

  ORDER_STAGE --> PAY_STAGE

  classDef user fill:#ffffff,stroke:#4b7099,color:#1e293b,stroke-width:2px;
  classDef service fill:#f0f4f8,stroke:#4b7099,color:#1e293b,stroke-width:2px;
  classDef message fill:#edf6f5,stroke:#4f7a74,color:#1e293b,stroke-width:2px;
  classDef success fill:#f0fdf4,stroke:#15803d,color:#14532d,stroke-width:2px;
