  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'X-Trace-Id', value: `postman-${Date.now()}` });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 Auth",
      "item": [
        {
          "name": "Login success",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json;charset=UTF-8" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"loginType\": \"PASSWORD\"\n}" },
            "url": { "raw": "{{BaseURL}}/api/v1/auth/login", "host": ["{{BaseURL}}"], "path": ["api", "v1", "auth", "login"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                "const body = pm.response.json();",
                "pm.test('business code 200', () => pm.expect(body.code).to.eql(200));",
                "pm.test('access token returned', () => pm.expect(body.data.accessToken).to.be.a('string').and.not.empty);",
                "pm.environment.set('token', body.data.accessToken);",
                "pm.environment.set('refreshToken', body.data.refreshToken || '');"
              ]
            }
          }]
        },
        {
          "name": "Login wrong password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json;charset=UTF-8" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"wrong-password\",\n  \"loginType\": \"PASSWORD\"\n}" },
            "url": { "raw": "{{BaseURL}}/api/v1/auth/login", "host": ["{{BaseURL}}"], "path": ["api", "v1", "auth", "login"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('request completed', () => pm.expect(pm.response.code).to.be.oneOf([200, 400, 401]));",
              "const body = pm.response.json();",
              "pm.test('login rejected', () => pm.expect(body.code).to.not.eql(200));"
            ] }
          }]
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json;charset=UTF-8" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{BaseURL}}/api/v1/auth/refresh", "host": ["{{BaseURL}}"], "path": ["api", "v1", "auth", "refresh"] }
          },
          "event": [{
            "listen": "test",
            "script": { "type": "text/javascript", "exec": [
              "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('business code 200', () => pm.expect(body.code).to.eql(200));",
              "pm.environment.set('token', body.data.accessToken);",
              "pm.environment.set('refreshToken', body.data.refreshToken || pm.environment.get('refreshToken'));"
            ] }
          }]
        }
      ]
