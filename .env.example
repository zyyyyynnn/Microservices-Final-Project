# =====================================================
# MallCloud 环境变量模板
# 拷贝：cp .env.example .env
# =====================================================

# Spring 环境
SPRING_PROFILES_ACTIVE=dev

# Nacos
NACOS_SERVER=127.0.0.1:8848
NACOS_NAMESPACE=dev
NACOS_USER=nacos
NACOS_PASSWORD=nacos

# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PWD=root

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PWD=

# RocketMQ
ROCKETMQ_NAMESRV=127.0.0.1:9876

# Elasticsearch
ES_HOST=127.0.0.1
ES_PORT=9200

# Seata
SEATA_TC_URL=127.0.0.1:8091

# Sentinel
SENTINEL_DASHBOARD=127.0.0.1:8080

# Zipkin
ZIPKIN_URL=http://127.0.0.1:9411

# JWT
JWT_SECRET=mallcloud-dev-jwt-secret-20260609-rotated-after-report-leak-change-me-hs512-signing-key
JWT_ACCESS_EXPIRE=7200
JWT_REFRESH_EXPIRE=604800
